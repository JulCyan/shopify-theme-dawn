{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'template-collection.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .jd-featured-products__meta {
    margin-top: 0.8rem;
    font-size: 1.3rem;
    line-height: 1.4;
    color: rgba(var(--color-foreground), 0.75);
  }

  .jd-featured-products__empty {
    margin-top: 1.6rem;
  }
{%- endstyle -%}

{%- liquid
  # Section-level setup:
  # - cards_above_fold controls which cards load eagerly
  # - namespace/key decide which product metafield to read
  assign columns_desktop = section.settings.columns_desktop | plus: 0
  assign cards_above_fold = columns_desktop
  assign metafield_namespace = section.settings.metafield_namespace | strip
  assign metafield_key = section.settings.metafield_key | strip
-%}

<section class="jd-featured-products color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width section-{{ section.id }}-padding">
    {%- if section.settings.title != blank -%}
      <h2 class="title inline-richtext {{ section.settings.heading_size }}">{{ section.settings.title }}</h2>
    {%- endif -%}

    {%- if section.settings.collection == blank -%}
      {%- comment -%}
        Empty state is intentional: this tells merchant the section is wired correctly,
        but still needs a collection assignment in Theme Editor.
      {%- endcomment -%}
      <div class="jd-featured-products__empty rte">
        <p>Select a collection in Theme Editor to load real store products.</p>
      </div>
    {%- else -%}
      <ul
        class="grid product-grid contains-card contains-card--product grid--{{ section.settings.columns_desktop }}-col-desktop grid--{{ section.settings.columns_mobile }}-col-tablet-down"
        role="list"
      >
        {%- for product in section.settings.collection.products limit: section.settings.products_to_show -%}
          {%- liquid
            # Above-the-fold cards are eager, below fold cards are lazy.
            assign lazy_load = true
            if forloop.index <= cards_above_fold
              assign lazy_load = false
            endif

            # Optional metafield rendering:
            # product.metafields[namespace][key] can return typed metafield objects.
            # We prefer .value and fallback to raw value for compatibility.
            assign metafield_display = blank
            if section.settings.show_metafield_badge and metafield_namespace != blank and metafield_key != blank
              assign mf = product.metafields[metafield_namespace][metafield_key]
              if mf != blank
                assign metafield_display = mf.value | default: mf
              endif
            endif
          -%}

          <li class="grid__item">
            {% render 'card-product',
              card_product: product,
              media_aspect_ratio: section.settings.image_ratio,
              image_shape: 'default',
              lazy_load: lazy_load,
              show_secondary_image: section.settings.show_secondary_image,
              show_vendor: section.settings.show_vendor,
              show_rating: false,
              section_id: section.id,
              quick_add: 'none'
            %}

            {%- if metafield_display != blank -%}
              <p class="jd-featured-products__meta">{{ metafield_display | escape }}</p>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "JD Featured Products",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "Heading",
      "default": "Real product data practice"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "default": "h2",
      "options": [
        {
          "value": "h2",
          "label": "H2"
        },
        {
          "value": "h1",
          "label": "H1"
        },
        {
          "value": "h0",
          "label": "H0"
        }
      ]
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "label": "Products to show",
      "default": 4
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Desktop columns",
      "default": "4",
      "options": [
        {
          "value": "2",
          "label": "2"
        },
        {
          "value": "3",
          "label": "3"
        },
        {
          "value": "4",
          "label": "4"
        }
      ]
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Mobile columns",
      "default": "2",
      "options": [
        {
          "value": "1",
          "label": "1"
        },
        {
          "value": "2",
          "label": "2"
        }
      ]
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image ratio",
      "default": "adapt",
      "options": [
        {
          "value": "adapt",
          "label": "Adapt"
        },
        {
          "value": "portrait",
          "label": "Portrait"
        },
        {
          "value": "square",
          "label": "Square"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "show_secondary_image",
      "label": "Show secondary image",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show vendor",
      "default": false
    },
    {
      "type": "header",
      "content": "Metafield output"
    },
    {
      "type": "checkbox",
      "id": "show_metafield_badge",
      "label": "Show product metafield text",
      "default": true
    },
    {
      "type": "text",
      "id": "metafield_namespace",
      "label": "Metafield namespace",
      "default": "custom"
    },
    {
      "type": "text",
      "id": "metafield_key",
      "label": "Metafield key",
      "default": "marketing_badge"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "JD Featured Products"
    }
  ]
}
{% endschema %}
