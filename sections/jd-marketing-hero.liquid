{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .jd-marketing-hero__content {
    display: grid;
    gap: 2.4rem;
  }

  .jd-marketing-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1.2rem;
  }

  .jd-marketing-hero__features {
    display: grid;
    gap: 1.6rem;
    grid-template-columns: 1fr;
  }

  .jd-marketing-hero__feature {
    padding: 1.6rem;
    border-radius: var(--text-boxes-radius);
    border: 0.1rem solid rgba(var(--color-foreground), 0.16);
    background: rgba(var(--color-background), 0.65);
  }

  @media screen and (min-width: 750px) {
    .jd-marketing-hero__features {
      grid-template-columns: repeat({{ section.settings.columns_desktop }}, minmax(0, 1fr));
    }
  }
{%- endstyle -%}

<section class="jd-marketing-hero color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width section-{{ section.id }}-padding">
    {%- liquid
      # 标题标签可配置，便于在不同页面里保持合理的语义层级（h1/h2/h3）。
      assign heading_tag = section.settings.heading_tag | default: 'h2'
      assign hero_heading_text = section.settings.heading | strip_html | strip

      # aria-label 兜底：商家未填写时，使用标题文本给读屏器提供区域说明。
      assign hero_region_label = section.settings.aria_label
      if hero_region_label == blank
        assign hero_region_label = hero_heading_text
      endif

      # 图片 alt 兜底：优先用配置值；为空时回退到标题文本。
      assign hero_image_alt = section.settings.image_alt
      if hero_image_alt == blank
        assign hero_image_alt = hero_heading_text
      endif
    -%}

    <div class="jd-marketing-hero__content">
      {%- if section.settings.background_image != blank -%}
        <div class="media media--adapt">
          {%- comment -%}
            图片尺寸策略保持简单可控：
            - 大屏按主题 page_width 封顶
            - 小屏按视口宽度 100vw
          {%- endcomment -%}
          {% capture image_sizes %}
            (min-width: {{ settings.page_width }}px) {{ settings.page_width }}px,
            100vw
          {% endcapture %}
          {{
            section.settings.background_image
            | image_url: width: 2400
            | image_tag:
              widths: '480, 750, 1024, 1440, 1920, 2400',
              sizes: image_sizes,
              loading: section.settings.image_loading,
              fetchpriority: section.settings.image_fetchpriority,
              alt: hero_image_alt,
              class: 'jd-marketing-hero__image'
          }}
        </div>
      {%- endif -%}

      <header role="region" aria-label="{{ hero_region_label | escape }}">
        {%- if section.settings.kicker != blank -%}
          <p class="caption-with-letter-spacing">{{ section.settings.kicker | escape }}</p>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <{{ heading_tag }} class="h1 inline-richtext">{{ section.settings.heading }}</{{ heading_tag }}>
        {%- endif -%}

        {%- if section.settings.description != blank -%}
          <div class="rte">{{ section.settings.description }}</div>
        {%- endif -%}
      </header>

      {%- if section.settings.primary_button_label != blank or section.settings.secondary_button_label != blank -%}
        <div class="jd-marketing-hero__actions">
          {%- if section.settings.primary_button_label != blank -%}
            <a
              class="button button--primary"
              {% if section.settings.primary_button_link == blank %}
                role="link"
                aria-disabled="true"
              {% else %}
                href="{{ section.settings.primary_button_link }}"
              {% endif %}
            >
              {{ section.settings.primary_button_label | escape }}
            </a>
          {%- endif -%}

          {%- if section.settings.secondary_button_label != blank -%}
            <a
              class="button button--secondary"
              {% if section.settings.secondary_button_link == blank %}
                role="link"
                aria-disabled="true"
              {% else %}
                href="{{ section.settings.secondary_button_link }}"
              {% endif %}
            >
              {{ section.settings.secondary_button_label | escape }}
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <ul class="jd-marketing-hero__features list-unstyled" role="list">
          {%- for block in section.blocks -%}
            {%- comment -%}
              Theme Editor 必须带上 block.shopify_attributes：
              否则后台里的 block 高亮、定位、拖拽交互会异常。
            {%- endcomment -%}
            <li class="jd-marketing-hero__feature" {{ block.shopify_attributes }}>
              {%- if block.settings.title != blank -%}
                <h3 class="h4">{{ block.settings.title | escape }}</h3>
              {%- endif -%}

              {%- if block.settings.description != blank -%}
                <p>{{ block.settings.description | escape }}</p>
              {%- endif -%}

              {%- if block.settings.link_label != blank -%}
                <a
                  class="link underlined-link"
                  {% if block.settings.link == blank %}
                    role="link"
                    aria-disabled="true"
                  {% else %}
                    href="{{ block.settings.link }}"
                  {% endif %}
                >
                  {{ block.settings.link_label | escape }}
                </a>
              {%- endif -%}
            </li>
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "JD 营销主视觉",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "配色方案",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "前置短语",
      "default": "面向独立站增长的内容舞台"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "标题",
      "default": "让内容配置和页面交付更快、更稳"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "标题标签",
      "default": "h2",
      "options": [
        {
          "value": "h1",
          "label": "H1"
        },
        {
          "value": "h2",
          "label": "H2"
        },
        {
          "value": "h3",
          "label": "H3"
        }
      ]
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "描述",
      "default": "<p>用于展示项目主张、关键能力和下一步行动，支持在主题编辑器中快速调整文案与结构。</p>"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "背景图"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "图片替代文本",
      "info": "留空时会自动使用标题文本。"
    },
    {
      "type": "select",
      "id": "image_loading",
      "label": "图片加载策略",
      "default": "lazy",
      "options": [
        {
          "value": "lazy",
          "label": "懒加载"
        },
        {
          "value": "eager",
          "label": "立即加载"
        }
      ]
    },
    {
      "type": "select",
      "id": "image_fetchpriority",
      "label": "图片抓取优先级",
      "default": "auto",
      "options": [
        {
          "value": "auto",
          "label": "自动"
        },
        {
          "value": "high",
          "label": "高"
        },
        {
          "value": "low",
          "label": "低"
        }
      ]
    },
    {
      "type": "text",
      "id": "aria_label",
      "label": "区块无障碍标签",
      "info": "供读屏器使用，留空时自动回退为标题文本。"
    },
    {
      "type": "text",
      "id": "primary_button_label",
      "label": "主按钮文案",
      "default": "查看功能"
    },
    {
      "type": "url",
      "id": "primary_button_link",
      "label": "主按钮链接"
    },
    {
      "type": "text",
      "id": "secondary_button_label",
      "label": "次按钮文案",
      "default": "浏览案例"
    },
    {
      "type": "url",
      "id": "secondary_button_link",
      "label": "次按钮链接"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 4,
      "step": 1,
      "label": "桌面端特性列数",
      "default": 3
    },
    {
      "type": "header",
      "content": "区块边距"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "上边距",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "下边距",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "特性卡片",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "标题",
          "default": "可配置能力点"
        },
        {
          "type": "text",
          "id": "description",
          "label": "描述",
          "default": "说明这一项如何帮助项目在真实场景中落地。"
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "链接文案",
          "default": "了解详情"
        },
        {
          "type": "url",
          "id": "link",
          "label": "链接"
        }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "JD 营销主视觉",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "title": "Section + Schema 设计",
            "description": "将关键业务字段暴露到主题编辑器，方便运营独立调整。"
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Blocks 组合能力",
            "description": "支持增删和重排，快速匹配不同活动页面诉求。"
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "交付可验证",
            "description": "结构清晰，便于联调、验收和后续维护。"
          }
        }
      ]
    }
  ]
}
{% endschema %}
